   "source": [
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "print(\"A gerar o painel de Análise Exploratória...\\n\")\n",
    "\n",
    "# Configuração de estilo para deixar os gráficos com aspeto profissional\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "\n",
    "# Cria uma figura grande para caberem 2 gráficos lado a lado\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
    "\n",
    "# ==========================================\n",
    "# GRÁFICO 1: O Balanceamento do Churn\n",
    "# ==========================================\n",
    "# Conta a quantidade de clientes ativos (0) e cancelados (1)\n",
    "sns.countplot(data=df_final_eda, x='churned', ax=axes[0], palette=['#2ecc71', '#e74c3c'])\n",
    "axes[0].set_title('Visão Geral: Status de Cancelamento (Churn)', fontsize=14, fontweight='bold')\n",
    "axes[0].set_xlabel('Status (0 = Ativo | 1 = Cancelou)', fontsize=12)\n",
    "axes[0].set_ylabel('Número de Clientes', fontsize=12)\n",
    "\n",
    "# ==========================================\n",
    "# GRÁFICO 2: Tipo de Veículo vs. Churn\n",
    "# ==========================================\n",
    "# Mostra a taxa (%) de cancelamento para cada categoria de veículo que você tratou\n",
    "sns.barplot(data=df_final_eda, x='tipo_veiculo', y='churned', ax=axes[1], palette='magma', errorbar=None)\n",
    "axes[1].set_title('Taxa de Churn por Tipo de Veículo', fontsize=14, fontweight='bold')\n",
    "axes[1].set_xlabel('Categoria do Veículo', fontsize=12)\n",
    "axes[1].set_ylabel('Taxa de Cancelamento (%)', fontsize=12)\n",
    "\n",
    "# Ajusta o espaçamento para não sobrepor textos\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ==========================================\n",
    "# CÁLCULO DE ESTATÍSTICA RÁPIDA\n",
    "# ==========================================\n",
    "taxa_global = df_final_eda['churned'].mean() * 100\n",
    "print(f\"Taxa Global de Churn da Seguradora: {taxa_global:.2f}%\")"
   ]
  },
