   "metadata": {},
   "source": [
    "\n",
    "Análise Exploratória - Unindo tabelas\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "9b830790-7534-4273-a6d8-6163e4fdd924",
   "metadata": {},
   "outputs": [
    {
     "metadata": {
      "url": "/api/outputs/3e35a6d8-048a-4c2f-91c2-33e7ab01d9c4/9b830790-7534-4273-a6d8-6163e4fdd924/0.output"
     },
     "output_type": "stream",
     "text": []
    },
    {
     "metadata": {
      "url": "/api/outputs/3e35a6d8-048a-4c2f-91c2-33e7ab01d9c4/9b830790-7534-4273-a6d8-6163e4fdd924/1.output"
     },
     "output_type": "display_data"
    }
   ],
   "source": [
    "import pandas as pd\n",
    "from functools import reduce\n",
    "\n",
    "print(\"A carregar os ficheiros limpos para a Análise Exploratória...\")\n",
    "\n",
    "# Todos ficheiros \n",
    "df_sinistros = pd.read_csv('Atendimento_Sinistros_Tratado_Final.csv')\n",
    "df_mkt = pd.read_csv('Engajamento_Marketing_Tratado_Final.csv')\n",
    "df_contratos = pd.read_csv('contratos_apolices_tratada.csv') \n",
    "df_cadastro  = pd.read_csv('cadastro_clientes_tratada.csv')\n",
    "df_churn = pd.read_csv('churn_.csv')\n",
    "\n",
    "# Criação da tabela unificada\n",
    "dfs = [df_contratos, df_cadastro, df_sinistros, df_mkt, df_churn]\n",
    "\n",
    "# Pradronização dos ID's\n",
    "print(\"A padronizar as chaves de cruzamento...\")\n",
    "for df in dfs:\n",
    "    # Nome da primeira coluna (seja id_cliente ou cod_individuo)\n",
    "    col_id = df.columns[0]\n",
    "    # Troca para cod_individuo\n",
    "    df.rename(columns={col_id: 'cod_individuo'}, inplace=True)\n",
    "    \n",
    "    # Garante que não há \"IND-\" ou espaços vindos das outras tabelas\n",
    "    df['cod_individuo'] = df['cod_individuo'].astype(str).str.replace('IND-', '', regex=False).str.replace('.0', '', regex=False).str.strip()\n",
    "\n",
    "# 3. O cruzamento agora é direto e limpo!\n",
    "print(\"A cruzar as tabelas...\")\n",
    "df_final_eda = reduce(lambda left, right: pd.merge(left, right, on='cod_individuo', how='inner'), dfs)\n",
    "\n",
    "print(f\"\\nSucesso! A base unificada para os gráficos tem {len(df_final_eda)} linhas e {df_final_eda.shape[1]} colunas.\")\n",
    "\n",
    "# Exibe as primeiras linhas para confirmar\n",
    "display(df_final_eda.head())"
   ]
  },
  {
   "cell_type": "code",
